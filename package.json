{
  "name": "aetheron-platform",
  "version": "2.0.0",
  "description": "Revolutionary Blockchain & Space Exploration Ecosystem",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "npx http-server . -p 3000",
    "dev": "npx http-server . -p 3000 -o",
    "build": "echo 'Static site - no build needed'",
    "test": "npm run test:smoke",
    "test:dashboard": "jest --config jest.config.cjs dashboard.test.js",
    "test:dashboard:jest": "node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --config jest.config.cjs dashboard.test.js",
    "test:diagnose": "jest --showConfig --runInBand --runTestsByPath dashboard.test.js",
    "test:smoke": "node dashboard.test.simple.js",
    "test:smart-contract": "cd smart-contract && npm test",
    "deploy": "echo 'Deploy manually to GitHub Pages'",
    "verify": "cd smart-contract && node scripts/verify-contracts.mjs",
    "hardhat:compile": "set APPDATA=%CD%\\.appdata&& set LOCALAPPDATA=%CD%\\.localappdata&& cd smart-contract && npx hardhat compile",
    "hardhat:test": "set APPDATA=%CD%\\.appdata&& set LOCALAPPDATA=%CD%\\.localappdata&& cd smart-contract && npx hardhat test"
  },
  "keywords": [
    "blockchain",
    "space-exploration",
    "defi",
    "web3",
    "aetheron",
    "react-native",
    "ethereum",
    "polygon"
  ],
  "author": "MastaTrill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MastaTrill/Aetheron_platform.git"
  },
  "bugs": {
    "url": "https://github.com/MastaTrill/Aetheron_platform/issues"
  },
  "homepage": "https://mastatrill.github.io/Aetheron_platform",
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@openzeppelin/contracts": "^5.4.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "io-ts": "^2.2.22",
    "next": "^16.1.6",
    "nodemailer": "^8.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "stripe": "^20.3.1",
    "web3": "^4.16.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@nomiclabs/hardhat-ethers": "^2.2.2",
    "@nomiclabs/hardhat-waffle": "^2.0.3",
    "chai": "^4.3.7",
    "eslint": "^4.1.1",
    "ethereum-waffle": "^4.0.10",
    "ethers": "^5.7.2",
    "hardhat": "^2.28.6",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.8.1"
  }
}
