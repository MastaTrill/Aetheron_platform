{
  "name": "aetheron-platform",
  "version": "2.0.0",
  "description": "Revolutionary Blockchain & Space Exploration Ecosystem",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "npx http-server . -p 3000",
    "dev": "npx http-server . -p 3000 -o",
    "build": "npm run build:metamask-connect && node build-cloudflare-dist.cjs",
    "build:metamask-connect": "node build-dashboard-metamask-connect.cjs",
    "test": "npm run test:smoke",
    "test:dashboard": "node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --config jest.config.cjs dashboard.test.js",
    "test:dashboard:jest": "node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --config jest.config.cjs dashboard.test.js",
    "test:diagnose": "jest --showConfig --runInBand --runTestsByPath dashboard.test.js",
    "test:smoke": "node dashboard.test.simple.js",
    "test:smart-contract": "node run-smart-contract.cjs test",
    "deploy": "echo 'Deploy manually to GitHub Pages'",
    "verify": "node run-smart-contract.cjs verify",
    "hardhat:compile": "node run-smart-contract.cjs compile",
    "hardhat:test": "node run-smart-contract.cjs test"
  },
  "keywords": [
    "blockchain",
    "space-exploration",
    "defi",
    "web3",
    "aetheron",
    "react-native",
    "ethereum",
    "polygon"
  ],
  "author": "MastaTrill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MastaTrill/Aetheron_platform.git"
  },
  "bugs": {
    "url": "https://github.com/MastaTrill/Aetheron_platform/issues"
  },
  "homepage": "https://aetrs.com",
  "overrides": {
    "undici": "^7.24.0",
    "js-yaml": "^4.2.0",
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@metamask/connect-multichain": "^0.11.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.15.0",
    "express": "^5.2.1",
    "nodemailer": "^9.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "esbuild": "^0.28.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.0",
    "linkedom": "^0.18.12",
    "prettier": "^3.8.1"
  }
}
