  "repository": {
    "type": "git",
    "url": "https://github.com/Mastatrill/aetheron-platform.git"
  },
  "bugs": {
    "url": "https://github.com/Mastatrill/aetheron-platform/issues"
  },
  "homepage": "https://mastatrill.github.io/aetheron-platform",
  "dependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "hardhat": "^3.1.12",
    "next": "^16.1.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "^0.74.0",
    "web3": "^4.16.0"
  },
  "devDependencies": {
