{
  "name": "aetheron-platform",
  "version": "2.0.0",
  "description": "Revolutionary Blockchain & Space Exploration Ecosystem",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next build",
    "test": "jest",
    "test:frontend": "jest",
    "test:contracts": "cd smart-contract && npx hardhat test",
    "gh-pages": "npm run export && cp -r out/* docs/ || xcopy /E /I /Y out docs",
    "deploy": "npm run gh-pages && git add docs && git commit -m \"Update GitHub Pages\" && git push"
  },
  "keywords": [
    "blockchain",
    "space-exploration",
    "defi",
    "web3",
    "aetheron",
    "react-native",
    "ethereum",
    "polygon"
  ],
