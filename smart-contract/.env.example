# Smart Contract Deployment Environment
# Copy to .env and fill in your values

# Your wallet private key (with MATIC for gas)
PRIVATE_KEY=0xYour64CharacterPrivateKeyHere

# Polygon RPC URL (get from Alchemy, Infura, or Polygon)
POLYGON_RPC_URL=https://polygon-rpc.com

# Contract addresses for verification (set after deployment)
AETHERON_STAKING_ADDRESS=0x0000000000000000000000000000000000000000

# Explorer API keys for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here