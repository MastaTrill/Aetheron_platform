{
  "type": "module",
  "name": "aetheron-smart-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for Aetheron Platform",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "node -e \"console.log('Coverage tooling was removed during dependency hardening. Re-add solidity-coverage if you need contract coverage reports.')\"",
    "deploy:local": "hardhat run scripts/deploy.mjs --network hardhat",
    "deploy:mumbai": "hardhat run scripts/deploy.mjs --network mumbai",
    "deploy:polygon": "hardhat run scripts/deploy.mjs --network polygon",
    "deploy:sepolia": "hardhat run scripts/deploy.mjs --network sepolia",
    "verify": "node scripts/verify-contracts.mjs",
    "verify:mumbai": "node scripts/verify-contracts.mjs mumbai",
    "verify:polygon": "node scripts/verify-contracts.mjs polygon",
    "verify:sepolia": "node scripts/verify-contracts.mjs sepolia",
    "node": "hardhat node",
    "clean": "hardhat clean"
  },
  "keywords": [
    "solidity",
    "ethereum",
    "polygon",
    "smart-contracts",
    "hardhat",
    "aetheron"
  ],
  "author": "MastaTrill",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.11",
    "@openzeppelin/contracts-upgradeable": "^4.9.0",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.12"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.8.0",
    "dotenv": "^16.3.1"
  },
  "overrides": {
    "undici": "^6.24.1"
  },
  "directories": {
    "test": "test"
  }
}
