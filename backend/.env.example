# Backend environment template for Aetheron
# Copy this file to backend/.env and replace placeholder values.

# Server
PORT=4000

# Launchpad deployment
POLYGON_RPC_URL=https://polygon-rpc.com
DEPLOYER_PRIVATE_KEY=0xyour64hexprivatekey
TEAM_WALLET=0xYourTeamWalletHere

# Optional launchpad metadata
DEFAULT_TOKEN_DECIMALS=18
DEFAULT_ALLOCATION_PERCENT=1

# Push notifications
WALLET_ADDRESSES=0xYourWallet1,0xYourWallet2
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-rest-api-key
USER_MAP={"0xyourwallet1":"onesignal-player-id-1","0xyourwallet2":"onesignal-player-id-2"}

# Optional commerce / email integrations
COINBASE_COMMERCE_API_KEY=your-coinbase-commerce-api-key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=notifications@mastatrill.github.io
